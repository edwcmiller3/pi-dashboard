<?xml version="1.0"?>
<!--
  labwc compositor config for the Pi kiosk. Installs to ~/.config/labwc/rc.xml.

    - <touch mouseEmulation="no" />
        Touch is reported as touch, not an emulated pointer. This is the primary
        cursor fix: with mouse-emulation ON (the default), every tap spawns/moves
        a pointer and tap-drag selects text instead of scrolling. OFF gives
        correct tap/scroll on the 10-point panel and stops touch from ever
        materializing a cursor.

    - HideCursor keybind  (needs labwc >= 0.8.4)
        labwc has no idle-hide-cursor config, so cursor suppression is layered:
        (1) mouseEmulation="no" above means touch never shows a pointer; (2) the
        page sets CSS `cursor:none` for the in-page layer; (3) Chromium
        autostarts fullscreen so the bare-labwc state (where a stray pointer can
        sit) never persists. This keybind is a manual fallback to hide the
        cursor on demand if one ever appears.

  Deliberately NOT set:
    - NO <touch><calibrationMatrix> — touch is already aligned at all corners.
    - NO <autoEnableOutputs>no</autoEnableOutputs> — it stops labwc driving the
      single fixed panel at all (text console stays up, wlopm lists no output).
      The panel must stay driven while the box is powered; nightly darkness
      comes from the smart-plug power-off window, not an output power state.
-->
<labwc_config>

  <touch mouseEmulation="no" />

  <keyboard>
    <keybind key="W-c">
      <action name="HideCursor" />
    </keybind>
  </keyboard>

</labwc_config>
