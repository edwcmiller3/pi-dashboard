# Copy to .env and fill in. .env is git-ignored — never commit it.

# --- Calendar (SECRET + PII-bearing) ---
# Proton Calendar "Full view" ICS URL. The URL embeds the decryption key inline,
# so treat it as a credential: keep it in 1Password, paste it here locally only,
# never commit, never log. See README "Secrets & data handling".
PROTON_ICS_URL=

# --- Local bind (spec §5) ---
HOST=127.0.0.1
PORT=8000

# --- Weather (Open-Meteo) — set to YOUR location; example default is NYC City Hall ---
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
# Per-source refresh TTLs (seconds). The background loop ticks at the SHORTEST
# TTL; a source is only refetched once its own TTL has elapsed (or on POST /refresh).
WEATHER_TTL_SECONDS=900

# --- Weather: forecast model + optional NWS observation overlay ---
# Open-Meteo forecast model (its models= param). Unset/empty = "best_match"
# (the provider default). US deployments may prefer "ncep_nbm_conus" (NOAA's
# calibrated blend) — judge it against best_match over ~2 weeks before pinning.
#WEATHER_MODEL=ncep_nbm_conus
# NWS station ID (e.g. KOQT) for REAL current-conditions observations on the
# hero: temp / feels-like / humidity / wind / condition come from the station's
# latest measurement instead of the forecast model. US-only (api.weather.gov);
# empty/unset = off (hero stays pure Open-Meteo). Fail-soft: any NWS hiccup
# just falls back to the model for that refresh. Find your nearest station:
#   curl -H "User-Agent: you@example.com" \
#     "https://api.weather.gov/points/{lat},{lon}" | jq -r .properties.observationStations
#   (then GET that URL; the first station listed is nearest)
NWS_STATION=
# Sent on every NWS call. api.weather.gov REQUIRES a User-Agent and asks that
# it include contact info so they can reach you about problem traffic —
# personalize it. Unset = a generic default carrying only the repo URL.
#NWS_USER_AGENT=pi-dashboard (you@example.com)

# --- Calendar refresh ---
CALENDAR_TTL_SECONDS=900

# --- Cache ---
CACHE_DIR=var

# --- Theme (optional) ---
# Palette override: the name of a stylesheet in static/themes/ (without ".css"),
# e.g. THEME=nord. Served at /theme.css after style.css so its :root block wins.
# Empty/unset or invalid = the built-in palette.
THEME=
